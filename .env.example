# Copie para .env e preencha com os valores reais.
# Projeto: ferramenta de pesquisa de interesses Meta Ads.

# Meta Graph API
# Aceita ACCESS_TOKEN ou META_ACCESS_TOKEN
ACCESS_TOKEN=
META_ACCESS_TOKEN=
META_API_VERSION=v19.0
META_LOCALE=pt_BR
# Opcional, mas recomendado para maior aderencia ao Direcionamento Detalhado:
# Use o ID da conta de anuncios (com ou sem prefixo act_).
META_AD_ACCOUNT_ID=

# Backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
REQUEST_TIMEOUT_SECONDS=20

# Filtro de relevancia da keyword (agente interno)
RELEVANCE_FILTER_ENABLED=true
RELEVANCE_THRESHOLD=0.32

# Google Ads OAuth + API
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_REDIRECT_URI=http://localhost:8080/callback
GOOGLE_ADS_API_VERSION=v20
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_DEFAULT_LANGUAGE_ID=1000
GOOGLE_ADS_DEFAULT_LOCATION_IDS=21167
GOOGLE_ADS_INCLUDE_ADULT_KEYWORDS=false
